# Your .gitignore should still exclude images but allow data/
cat > .gitignore << 'EOF'
# Large image directory (75k images = 14GB!)
images/

# Python cache (auto-generated)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# Environment files
.env
.venv
env/
venv/

# Temporary files
*.tmp
*.temp
*.log
EOF